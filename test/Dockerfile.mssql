FROM mcr.microsoft.com/azure-sql-edge:latest

USER root

# Install prerequisites
RUN apt-get update && apt-get install -y curl gnupg2 apt-transport-https

# Add Microsoft repository for mssql-tools18 (ARM64 compatible - using Ubuntu 22.04 repo)
RUN curl -sSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/microsoft-prod.gpg && \
    echo "deb [arch=arm64 signed-by=/usr/share/keyrings/microsoft-prod.gpg] https://packages.microsoft.com/ubuntu/22.04/prod jammy main" > /etc/apt/sources.list.d/mssql-tools18.list

# Install mssql-tools18
RUN apt-get update && \
    ACCEPT_EULA=Y apt-get install -y mssql-tools18 unixodbc-dev && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Add sqlcmd to PATH
ENV PATH="${PATH}:/opt/mssql-tools18/bin"

USER mssql
