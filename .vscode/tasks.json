      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$go"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "go: test",
      "type": "shell",
      "command": "go test ./...",
      "group": "test",
      "problemMatcher": ["$go"],
      "presentation": { "reveal": "always", "panel": "shared" }
