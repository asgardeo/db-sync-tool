/data/
*.json.tmp
cdc_cursor_state.json

# TLS certificates (keep only examples)
/certs/*.crt
/certs/*.key
/certs/*.pem
!/certs/.gitkeep

# Logs
*.log
/logs/

# OS files
.DS_Store
Thumbs.db

# Dependency directories (if using vendor)
/vendor/
